# GCN-Kafka credentials (register at https://gcn.nasa.gov)
GCN_CLIENT_ID=
GCN_CLIENT_SECRET=

# STDWeb API
STDWEB_URL=http://86.253.141.183:7000
STDWEB_TOKEN=

# TNS API credentials
TNS_BOT_ID=
TNS_BOT_NAME=
TNS_API_KEY=

# Email notifications (SMTP)
# Fill these in the Settings UI or here; password goes via the UI "Save" button
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_FROM=AstroBatch <you@gmail.com>
EMAIL_TO=you@example.com
# EMAIL_PASS → set via the Settings UI (stored encrypted in DB, never committed)
OBS_LAT=47.7
OBS_LON=-3.0

# AstroColibri enrichment (optional)
COLIBRI_UID=

# Alert filtering thresholds (optional)
ALERT_MIN_ALT_DEG=25
ALERT_MIN_MOON_SEP_DEG=20

# ToO mosaic FOV (degrees, inscribed circle on sensor). Prefer Settings → Telescope field of view.
# Fallback when telescope_fov_deg is not saved in the DB (default in UI: 0.86 for 250mm/750mm + IMX533).
TOO_FOV_DEG=0.86
# Mosaic: tile when err > FOV/2 (derived from telescope FOV); override with TOO_MOSAIC_THRESHOLD_DEG if needed
# TOO_MOSAIC_THRESHOLD_DEG=0.5
TOO_MOSAIC_MAX_SIDE=8
